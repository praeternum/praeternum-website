---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout
  title="協力会社募集｜Praeternum"
  description="ネットワーク工事の協力会社を募集しています。LINEとスマホで完結する、手離れのよい案件発注。"
  noindex={true}
>
  <Header />
  <main class="bg-white">
    <section class="max-w-3xl mx-auto px-6 py-24 md:py-32">
      <div class="mb-12">
        <span class="text-xs font-medium tracking-[0.2em] gradient-text uppercase">Partner recruitment</span>
        <h1 class="font-display text-3xl md:text-4xl font-medium mt-3 mb-5 text-brand-ink leading-tight">
          ネットワーク工事の<br />協力会社を募集しています
        </h1>
        <p class="text-base text-gray-600 leading-loose">
          LINEとスマホで完結する、手離れのよい案件発注。<br />
          まずは資料をお送りしますので、下記フォームよりご連絡先をお知らせください。
        </p>
      </div>

      <div class="bg-[#FAFAF7] rounded-2xl p-8 md:p-10 border border-gray-100">
        <h2 class="text-lg font-medium mb-6 text-brand-ink">資料請求フォーム</h2>

        <form class="space-y-5" action="#" method="post">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">お名前・屋号 <span class="text-pink-500">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-md border border-gray-200 text-sm focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">電話番号 または LINE ID <span class="text-pink-500">*</span></label>
            <input
              type="text"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-3 rounded-md border border-gray-200 text-sm focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">メールアドレス <span class="text-pink-500">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-md border border-gray-200 text-sm focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
            />
          </div>

          <div>
            <label for="area" class="block text-sm font-medium text-gray-700 mb-2">対応エリア</label>
            <input
              type="text"
              id="area"
              name="area"
              placeholder="例：大阪府全域、京都市、奈良北部など"
              class="w-full px-4 py-3 rounded-md border border-gray-200 text-sm focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
            />
          </div>

          <div>
            <label for="note" class="block text-sm font-medium text-gray-700 mb-2">ひとこと（任意）</label>
            <textarea
              id="note"
              name="note"
              rows="4"
              class="w-full px-4 py-3 rounded-md border border-gray-200 text-sm focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 transition"
            ></textarea>
          </div>

          <button
            type="submit"
            class="cta-btn text-white px-8 py-3.5 rounded-md text-sm font-medium w-full md:w-auto tracking-wide"
          >
            資料請求を送信する
          </button>
        </form>

        <p class="text-xs text-gray-500 mt-6 leading-relaxed">
          ※送信後、担当者より登録フォームのご案内をお送りします。<br />
          ※個人情報は資料送付およびご連絡以外の目的では使用いたしません。
        </p>
      </div>

      <div class="mt-16 pt-8 border-t border-gray-100 text-center">
        <p class="text-xs text-gray-500">© 2026 Praeternum. All rights reserved.</p>
      </div>
    </section>
  </main>
</BaseLayout>
