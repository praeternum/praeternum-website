---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}
const {
  title = 'Praeternum｜商談中に、工事日まで決まる。',
  description = '通信機器販売代理店・ディーラー向けのネットワーク工事代行。契約のその場で工事日確定、最短36時間後から着工、完了報告までPraeternumが一括代行します。',
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content="/logo@2x.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- 全画面固定の背景アニメーションレイヤー -->
    <div class="site-bg" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="blob blob-4"></div>
    </div>

    <slot />

    <!-- スクロール連動フェードイン -->
    <script is:inline>
      (function () {
        function init() {
          if (!('IntersectionObserver' in window)) {
            document.querySelectorAll('.reveal-on-scroll').forEach(function (el) {
              el.classList.add('in-view');
            });
            return;
          }
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('in-view');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
          );
          var targets = document.querySelectorAll('main > *');
          targets.forEach(function (el, index) {
            el.classList.add('reveal-on-scroll');
            if (index === 0) {
              el.classList.add('in-view');
            } else {
              observer.observe(el);
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <style is:global>
      /* ==== 背景アニメを見せるため、body/main/各セクションを強制透明化 ==== */
      html,
      body {
        background: transparent !important;
      }

      main,
      main > *,
      main > * > section {
        background-color: transparent !important;
        background-image: none !important;
      }

      /* ==== 全画面背景アニメーション ==== */
      .site-bg {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        overflow: hidden;
        background: #ffffff;
      }

      .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        will-change: transform;
      }

      .blob-1 {
        width: 520px;
        height: 520px;
        background: rgba(37, 99, 235, 0.32);
        top: -8%;
        left: -8%;
        animation: blobFloat1 22s ease-in-out infinite;
      }

      .blob-2 {
        width: 460px;
        height: 460px;
        background: rgba(16, 185, 129, 0.26);
        top: 28%;
        right: -12%;
        animation: blobFloat2 26s ease-in-out infinite;
      }

      .blob-3 {
        width: 580px;
        height: 580px;
        background: rgba(99, 102, 241, 0.24);
        bottom: -15%;
        left: 25%;
        animation: blobFloat3 30s ease-in-out infinite;
      }

      .blob-4 {
        width: 420px;
        height: 420px;
        background: rgba(14, 165, 233, 0.22);
        top: 58%;
        left: -8%;
        animation: blobFloat4 28s ease-in-out infinite;
      }

      @keyframes blobFloat1 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(20vw, 15vh) scale(1.15); }
        66% { transform: translate(-5vw, 30vh) scale(0.92); }
      }
      @keyframes blobFloat2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(-18vw, 20vh) scale(1.1); }
        66% { transform: translate(-28vw, -12vh) scale(0.95); }
      }
      @keyframes blobFloat3 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(15vw, -22vh) scale(0.88); }
        66% { transform: translate(-12vw, -35vh) scale(1.18); }
      }
      @keyframes blobFloat4 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(25vw, -18vh) scale(1.1); }
        66% { transform: translate(18vw, 22vh) scale(0.95); }
      }

      @media (prefers-reduced-motion: reduce) {
        .blob {
          animation: none !important;
        }
      }

      /* ==== スクロール連動フェードイン ==== */
      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(32px);
        transition:
          opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
      }

      .reveal-on-scroll.in-view {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal-on-scroll {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
