---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}
const {
  title = 'Praeternum｜商談中に、工事日まで決まる。',
  description = '通信機器販売代理店・ディーラー向けのネットワーク工事代行。契約のその場で工事日確定、最短36時間後から着工、完了報告までPraeternumが一括代行します。',
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content="/logo@2x.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script is:inline>
      (function () {
        function init() {
          // Hero（main直下の1番目の子）に一筆書き背景を挿入
          var hero = document.querySelector('main > *:first-child');
          if (hero && !hero.querySelector('.pr-hero-layer')) {
            hero.classList.add('pr-has-hero-layer');
            var bg = document.createElement('div');
            bg.className = 'pr-hero-layer';
            bg.setAttribute('aria-hidden', 'true');
            bg.innerHTML =
              '<svg class="pr-hero-layer-svg" viewBox="0 0 1400 280" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">' +
              '<text x="700" y="190" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="180" font-weight="600" fill="none" stroke="#2563eb" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" letter-spacing="-4" class="pr-logo-stroke">Praeternum</text>' +
              '</svg>';
            hero.insertBefore(bg, hero.firstChild);
          }

          // スクロール連動フェードイン
          if (!('IntersectionObserver' in window)) {
            document.querySelectorAll('.reveal-on-scroll').forEach(function (el) {
              el.classList.add('in-view');
            });
            return;
          }
          var observer = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('in-view');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
          );
          var targets = document.querySelectorAll('main > *');
          targets.forEach(function (el, index) {
            el.classList.add('reveal-on-scroll');
            if (index === 0) {
              el.classList.add('in-view');
            } else {
              observer.observe(el);
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>

    <style is:global>
      /* ==== Hero 一筆書き背景 ==== */
      /* Hero.astroの既存 .hero-bg クラスと衝突しないよう pr-* プレフィックス */
      main > *:first-child.pr-has-hero-layer {
        position: relative;
        overflow: hidden;
      }

      main > *:first-child.pr-has-hero-layer > *:not(.pr-hero-layer) {
        position: relative;
        z-index: 1;
      }

      .pr-hero-layer {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 8%;
      }

      .pr-hero-layer-svg {
        width: 100%;
        height: auto;
        max-width: 1100px;
      }

      .pr-logo-stroke {
        stroke-dasharray: 5000;
        stroke-dashoffset: 5000;
        opacity: 0;
        animation: drawLogo 10s ease-in-out infinite;
      }

      @keyframes drawLogo {
        0% {
          stroke-dashoffset: 5000;
          opacity: 0;
        }
        5% {
          opacity: 0.16;
        }
        50% {
          stroke-dashoffset: 0;
          opacity: 0.16;
        }
        75% {
          stroke-dashoffset: 0;
          opacity: 0.16;
        }
        95% {
          stroke-dashoffset: -5000;
          opacity: 0;
        }
        100% {
          stroke-dashoffset: -5000;
          opacity: 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .pr-logo-stroke {
          animation: none;
          stroke-dashoffset: 0;
          opacity: 0.1;
        }
      }

      /* ==== スクロール連動フェードイン ==== */
      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(32px);
        transition:
          opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
      }

      .reveal-on-scroll.in-view {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        .reveal-on-scroll {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
    </style>
  </body>
</html>
