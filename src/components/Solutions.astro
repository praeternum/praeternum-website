---
// Section 3: ソリューション - 4 solutions mapping to Shop pains
const solutions = [
  {
    number: '01',
    accentClass: 'sc-1',
    title: '契約のその場で、工事日確定',
    body: '商談中にPortalを開いて、空き枠をタップするだけ。お客さまの熱が冷める前に、契約から設置完了までの道筋をその場で見せられます。決裁の後押しに。',
  },
  {
    number: '02',
    accentClass: 'sc-2',
    title: '最短36時間後、現場が動く',
    body: '契約後の工事手配はPraeternumで完結。技術者の派遣、スケジュール調整、当日の現場管理まで、すべて引き受けます。貴社は本業の営業活動に集中できます。',
  },
  {
    number: '03',
    accentClass: 'sc-3',
    title: '完了報告まで、ひとつの窓口で',
    body: '工事写真、完了報告書、チェックリストはPraeternumが一括管理。電話やメールでの進捗確認は不要。Portalを開けば、いつでも最新の状況を確認できます。',
  },
  {
    number: '04',
    accentClass: 'sc-4',
    title: '過去の工事履歴が、次の提案材料に',
    body: 'お客さま先で「前回はどんな構成でしたっけ?」の瞬間。スマホから過去の工事報告書・構成図にすぐアクセス。その場で増設・リプレース提案につなげられます。',
  },
];
---

<section id="service" class="py-24 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-xs font-medium tracking-[0.2em] gradient-text uppercase">Solution</span>
      <h2 class="font-display text-3xl md:text-4xl font-medium mt-3 text-brand-ink">使う工事会社で、営業現場はこう変わる。</h2>
      <p class="text-sm text-gray-600 mt-4">発注から完了報告まで、ひとつのPortalで。営業現場に効く、工事会社のかたち。</p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {
        solutions.map((s) => (
          <article class={`solution-card ${s.accentClass} bg-white border border-gray-100 border-t-0 p-8 rounded-b-2xl rounded-tr-2xl`}>
            <div class="font-display text-xs font-medium tracking-[0.2em] text-indigo-600 mb-4">{s.number}</div>
            <h3 class="text-xl font-medium mb-4 leading-snug">{s.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{s.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
