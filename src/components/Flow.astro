---
// Section 4: 導入の流れ - 3 steps from contract to completion
const steps = [
  {
    number: '01',
    title: '商談中にPortalを開く',
    body: 'スマホまたはタブレットから専用Portalにログイン。お客さまと画面を共有しながら進行できます。',
  },
  {
    number: '02',
    title: '空き枠から工事日を選ぶ',
    body: 'エリア・機器種別・希望日に応じて、空き枠がリアルタイムで表示。お客さまと一緒に日程を決定します。',
  },
  {
    number: '03',
    title: 'あとはPraeternumにお任せ',
    body: '職人の手配、現場管理、完了報告書作成まで、すべて弊社で実施。完了時に結果をお送りします。',
  },
];
---

<section id="flow" class="bg-[#FAFAF7] py-24 md:py-28">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-xs font-medium tracking-[0.2em] gradient-text uppercase">How it works</span>
      <h2 class="font-display text-3xl md:text-4xl font-medium mt-3 text-brand-ink">3ステップで、工事完了まで</h2>
    </div>

    <ol class="space-y-5">
      {
        steps.map((step) => (
          <li class="flex gap-5 md:gap-7 items-start">
            <div class="flex-shrink-0 w-14 h-14 md:w-16 md:h-16 rounded-2xl gradient-bg text-white flex items-center justify-center font-display text-xl font-medium">
              {step.number}
            </div>
            <div class="flex-1 bg-white p-6 md:p-7 rounded-2xl border border-gray-100">
              <h3 class="text-lg font-medium mb-2">{step.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
