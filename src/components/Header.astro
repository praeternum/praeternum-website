---
// Sticky global header with anchor-based navigation to Top page sections
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/85 border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt="Praeternum" class="w-11 h-11 object-contain" />
      <span class="font-display text-2xl font-medium tracking-tight text-brand-ink">Praeternum</span>
    </a>
    <nav class="hidden md:flex gap-9 text-sm text-gray-600" aria-label="main navigation">
      <a href="/#service" class="nav-link">サービス</a>
      <a href="/#flow" class="nav-link">導入の流れ</a>
      <a href="/#coverage" class="nav-link">対応エリア</a>
      <a href="/#faq" class="nav-link">よくある質問</a>
      <a href="/#contact" class="nav-link">お問い合わせ</a>
    </nav>
    <a href="/#contact" class="hidden md:inline-block cta-btn text-white px-5 py-2.5 rounded-md text-sm font-medium">
      お問い合わせ
    </a>
  </div>
</header>
